pipeline{
    
    agent any

    tools{
        maven 'mymaven'
    }

    stages{
        
        stage('Parallel stage'){
            parallel{
                stage('Compile Code'){
                    steps{
                        git 'https://github.com/irabattiakshay/DevOpsCodeDemo.git'
                        sh 'mvn compile'

                    }
                }
                stage('Review the Code'){
                    steps{
                        sh 'mvn pmd:pmd'

                    }
                }
            }
        }

        stage('Test Code'){
            steps{
                sh 'mvn test'
            }
        }

        stage('Build Code'){
            steps{
                sh 'mvn package'
            }
        }

        stage('Deploy Code'){
            steps{
                echo "Deploying the code to the server"
            }
        }

    }
}