pipeline{

    agent none

    stages{
        stage('Compile Code'){
            agent{
                docker{
                    image 'maven:3.8.5-openjdk-17'
                }
            }
            steps{
                git 'https://github.com/irabattiakshay/DevOpsCodeDemo.git'
                sh 'mvn clean compile'
            }
        }

        stage('Test Code'){
            agent{
                docker{
                    image 'maven:3.8.5-openjdk-17'
                }
            }
            steps{
                git 'https://github.com/irabattiakshay/DevOpsCodeDemo.git'
                sh 'mvn clean test'
            }
        }
    }
}